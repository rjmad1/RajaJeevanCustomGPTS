rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: Get the user's role from their document in Firestore
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper: Is the user's status approved?
    function isApproved() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().status == 'approved';
    }
    
    // Helper: Is the user an admin or super_admin?
    function isAdmin() {
      return isApproved() && 
             (getUserData().role == 'admin' || getUserData().role == 'super_admin');
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Users can read their own profile. Admins can read all profiles.
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Creating profiles: Users can write their own profile during registration (done via functions but good to have fallback).
      // However, roles and status are restricted to prevent self-elevation.
      allow create: if isAuthenticated() && request.auth.uid == userId && 
                    (!request.resource.data.keys().hasAll(['role', 'status']) || 
                     (request.resource.data.role == 'authorized_user' && request.resource.data.status == 'pending_approval'));
                     
      // Updating profiles: Admins can update any profile. Users can only update their own name or lastLogin.
      allow update: if isAdmin() || 
                    (isAuthenticated() && request.auth.uid == userId && 
                     request.resource.data.role == resource.data.role && 
                     request.resource.data.status == resource.data.status);
                     
      allow delete: if isAdmin() && getUserData().role == 'super_admin';
    }

    // --- Categories Collection ---
    match /categories/{categoryId} {
      // Any approved user can read categories
      allow read: if isApproved();
      // Only admins can write categories
      allow write: if isAdmin();
    }

    // --- Agents Collection ---
    match /agents/{agentId} {
      // Any approved user can read agents
      allow read: if isApproved();
      // Only admins can write agents
      allow write: if isAdmin();
    }

    // --- Favorites Collection ---
    match /favorites/{favoriteId} {
      // Approved users can read and write their own favorites
      allow read, write: if isApproved() && (resource == null || request.auth.uid == resource.data.userId);
      // Allow create if userId matches authenticated user
      allow create: if isApproved() && request.auth.uid == request.resource.data.userId;
    }

    // --- Access Codes Collection ---
    match /access_codes/{codeId} {
      // Only admins can view or modify access codes. Normal users redeem via secure Cloud Functions.
      allow read, write: if isAdmin();
    }

    // --- Audit Logs Collection ---
    match /audit_logs/{logId} {
      // Only admins can view audit logs. Writes are handled via Cloud Functions.
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // --- Settings Collection ---
    match /settings/{settingId} {
      // Approved users can read settings
      allow read: if isApproved();
      // Only admins can write settings
      allow write: if isAdmin();
    }
  }
}
